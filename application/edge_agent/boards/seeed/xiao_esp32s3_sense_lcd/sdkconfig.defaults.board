CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

# Flash and PSRAM for XIAO ESP32S3 Sense (8 MB Flash + 8 MB PSRAM)
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y

# Keep display module enabled by default
CONFIG_APP_CLAW_LUA_MODULE_LCD=y

# Camera runtime defaults
CONFIG_CAMERA_OV2640=y
CONFIG_CAMERA_OV2640_AUTO_DETECT_DVP_INTERFACE_SENSOR=y
CONFIG_CAMERA_OV2640_DVP_RGB565_640X480_6FPS=y
CONFIG_CAMERA_OV2640_DVP_DEFAULT_FMT_RGB565_640X480_6FPS=y
CONFIG_CAMERA_OV3660=y
CONFIG_CAMERA_OV3660_AUTO_DETECT_DVP_INTERFACE_SENSOR=y
CONFIG_CAM_CTRL_DVP_DMA_BUFFER_SIZE=32768
